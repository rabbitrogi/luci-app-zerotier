{
	"luci-app-zerotier": {
		"description": "Grant UCI access for luci-app-zerotier",
		"read": {
			"uci": [ "zerotier" ],
			"ubus": {
				"luci": [ "getInitList" ],
				"zerotier": [ "status", "interfaces", "reload" ]
			}
		},
		"write": {
			"uci": [ "zerotier" ],
			"ubus": {
				"zerotier": [ "reload" ]
			}
		}
	}
}
